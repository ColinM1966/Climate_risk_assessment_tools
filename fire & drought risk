  function(
      raster_file,
      indicator,
      scenario,
      period
  ) {

    process_aoi_raster(
      raster_file = raster_file,
      indicator = indicator,
      scenario = scenario,
      period = period,
      aoi_sf = aoi_site,
      output_directory =
        raster_out_dir
    )
  }
) %>%
  mutate(
    across(
      c(
        AOI_AREA_HA_VECTOR,
        mean,
        weighted_mean,
        median,
        p75,
        p90,
        min,
        max,
        valid_covered_area_ha
      ),
      ~ round(.x, 5)
    )
  ) %>%
  arrange(
    scenario,
    period,
    indicator
  )

