  )
)

write_csv(
  change_long,
  change_long_file
)

# ------------------------------------------------------------
# 10. DIRECT FIRE-RISK CLASSIFICATION
# ------------------------------------------------------------
#
# The fire raster is assumed to be a 0-1 probability or
# suitability surface.
#
# This is a direct classification and is valid for one AOI.
# Relative quartile classification is not used.

fire_probability_class <- function(x) {

  case_when(
    is.na(x) ~
      NA_character_,

    x < 0 | x > 1 ~
      "Check fire raster value",

    x <= 0.25 ~
      "Low",

    x <= 0.50 ~
      "Moderate",

    x <= 0.75 ~
      "High",

    x <= 1.00 ~
      "Very High"
  )
}

fire_report <- change_long %>%
  filter(
    indicator == "Fire"
  ) %>%
  mutate(
    baseline_fire_class =
      fire_probability_class(
        baseline_weighted_mean
      ),

    future_fire_class =
      fire_probability_class(
        future_weighted_mean
      ),

    fire_change_interpretation =
      case_when(
        is.na(delta_weighted_mean) ~
          NA_character_,

        delta_weighted_mean > 0 ~
          "Modelled fire probability increases from baseline.",

        delta_weighted_mean < 0 ~
          "Modelled fire probability decreases from baseline.",

        TRUE ~
          "No change in mean modelled fire probability."
      )
  )

fire_report_file <- file.path(
  table_out_dir,
  paste0(
    aoi_name,
    "_fire_risk_report.csv"
  )
)

write_csv(
  fire_report,
  fire_report_file
)

