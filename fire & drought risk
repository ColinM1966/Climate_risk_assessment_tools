find_existing_file <- function(directory, candidate_names) {

  if (!dir.exists(directory)) {
    stop(
      "Raster directory does not exist:\n",
      directory
    )
  }

  available_files <- list.files(
    directory,
    full.names = TRUE,
    recursive = FALSE
  )

  available_basenames <- basename(
    available_files
  )

  for (candidate in candidate_names) {

    matched_position <- which(
      tolower(available_basenames) ==
        tolower(candidate)
    )

    if (length(matched_position) > 0) {
      return(
        available_files[
          matched_position[1]
        ]
      )
    }
  }

  stop(
    "\nCould not find the required raster in:\n",
    directory,
    "\n\nTried these filenames:\n",
    paste(candidate_names, collapse = "\n"),
    "\n\nAvailable files include:\n",
    paste(
      head(available_basenames, 30),
      collapse = "\n"
    )
  )
}

make_candidate_filenames <- function(
    prefixes,
    scenario,
    period,
    extension
) {

  map_chr(
    prefixes,
    function(prefix) {

      if (scenario == "baseline") {

        paste0(
          prefix,
          "_AllGCMs_historical_1981-2010.",
          extension
        )

      } else {

        paste0(
          prefix,
          "_AllGCMs_",
          scenario,
          "_",
          period,
          ".",
          extension
        )
      }
    }
  )
}

