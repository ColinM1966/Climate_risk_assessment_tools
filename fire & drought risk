# ------------------------------------------------------------
# 5. SAFE SUMMARY FUNCTIONS
# ------------------------------------------------------------

safe_mean <- function(x) {
  if (all(is.na(x))) {
    NA_real_
  } else {
    mean(x, na.rm = TRUE)
  }
}

safe_median <- function(x) {
  if (all(is.na(x))) {
    NA_real_
  } else {
    median(x, na.rm = TRUE)
  }
}

safe_quantile <- function(x, probability) {
  if (all(is.na(x))) {
    NA_real_
  } else {
    as.numeric(
      quantile(
        x,
        probs = probability,
        na.rm = TRUE,
        names = FALSE
      )
    )
  }
}

safe_min <- function(x) {
  if (all(is.na(x))) {
    NA_real_
  } else {
    min(x, na.rm = TRUE)
  }
}

safe_max <- function(x) {
  if (all(is.na(x))) {
    NA_real_
  } else {
    max(x, na.rm = TRUE)
  }
}

# ------------------------------------------------------------
# 6. EXACTEXTRACTR + CROPPED-RASTER FUNCTION
# ------------------------------------------------------------

process_aoi_raster <- function(
    raster_file,
    indicator,
    scenario,
    period,
    aoi_sf,
    output_directory
) {

  cat(
    "\n----------------------------------------\n"
  )

  cat(
    "Processing: ",
    indicator,
    " | ",
    scenario,
    " | ",
    period,
    "\n",
    sep = ""
  )

  cat(
    "Input: ",
    basename(raster_file),
    "\n",
    sep = ""
  )

  r <- rast(
    raster_file
  )

  if (nlyr(r) != 1) {
    stop(
      "Expected one raster layer in:\n",
      raster_file,
      "\nLayers found: ",
      nlyr(r)
    )
  }

  # Give every raster the same temporary layer name.
  names(r) <- "raster_value"

  # Transform AOI to raster CRS
  aoi_raster_crs <- st_transform(
    aoi_sf,
    crs(r)
  )

  aoi_vect <- vect(
    aoi_raster_crs
  )

  # Check spatial overlap
  raster_extent_polygon <- as.polygons(
    ext(r),
    crs = crs(r)
  )

  overlaps <- relate(
    aoi_vect,
    raster_extent_polygon,
    relation = "intersects"
  )

  if (!any(overlaps)) {
    stop(
      "The AOI does not overlap raster:\n",
      raster_file
    )
  }

  # ----------------------------------------------------------
  # CROP AND MASK THE ORIGINAL RASTER
  # ----------------------------------------------------------

  r_crop <- crop(
    r,
    aoi_vect,
    snap = "out"
  )

  if (ncell(r_crop) == 0) {
    stop(
      "Cropping produced no cells for:\n",
      raster_file
    )
  }

  r_crop <- mask(
    r_crop,
    aoi_vect
  )

  scenario_label <- if_else(
    scenario == "baseline",
    "historical",
    scenario
  )

  output_raster_name <- paste0(
    aoi_name,
    "_",
    indicator,
    "_",
    scenario_label,
    "_",
    period,
    "_cropped.tif"
  )

  output_raster_file <- file.path(
    output_directory,
    output_raster_name
  )

  # Float output is suitable for all indicators.
  # NAflag writes outside-AOI NoData as -9999.
  writeRaster(
    r_crop,
    output_raster_file,
    overwrite = TRUE,
    datatype = "FLT4S",
    NAflag = -9999,
    gdal = c(
      "COMPRESS=LZW",
      "TILED=YES"
    )
  )

  # ----------------------------------------------------------
  # EXACT AREA-WEIGHTED EXTRACTION
  # ----------------------------------------------------------

  extraction <- exact_extract(
    r,
    aoi_raster_crs,
    include_area = TRUE,
    progress = FALSE
  )[[1]]

  if (
    is.null(extraction) ||
      nrow(extraction) == 0
  ) {

    return(
      tibble(
        AOI_ID = aoi_sf$AOI_ID,
        AOI_NAME = aoi_sf$AOI_NAME,
        AOI_AREA_HA_VECTOR =
          aoi_sf$AOI_AREA_HA_VECTOR,
        scenario = scenario,
        period = period,
        indicator = indicator,
        mean = NA_real_,
        weighted_mean = NA_real_,
        median = NA_real_,
        p75 = NA_real_,
        p90 = NA_real_,
        min = NA_real_,
        max = NA_real_,
        n_intersecting_cells = 0,
        n_valid_cells = 0,
        valid_covered_area_ha = 0,
        cropped_raster =
          output_raster_file
      )
    )
  }

  cat(
    "Columns returned by exact_extract():\n"
  )

  print(
    names(extraction)
  )

  # Identify the raster-value column automatically
  information_columns <- c(
    "coverage_fraction",
    "area",
    "x",
    "y",
    "cell"
  )

  value_columns <- setdiff(
    names(extraction),
    information_columns
  )

  if (length(value_columns) == 0) {
    stop(
      "No raster-value column was returned by exact_extract().\n",
      "Columns found: ",
      paste(
        names(extraction),
        collapse = ", "
      )
    )
  }

  raster_value_column <-
    value_columns[1]

  extraction <- extraction %>%
    rename(
      value =
        all_of(raster_value_column)
    ) %>%
    mutate(
      covered_area_m2 =
        area *
        coverage_fraction,

      valid_covered_area_m2 =
        if_else(
          !is.na(value),
          covered_area_m2,
          0
        ),

      weighted_value =
        if_else(
          !is.na(value),
          value *
            covered_area_m2,
          0
        )
    )

  valid_area_m2 <- sum(
    extraction$valid_covered_area_m2,
    na.rm = TRUE
  )

  weighted_mean_value <- ifelse(
    valid_area_m2 > 0,
    sum(
      extraction$weighted_value,
      na.rm = TRUE
    ) /
      valid_area_m2,
    NA_real_
  )

  valid_values <- extraction$value[
    !is.na(extraction$value)
  ]

  result <- tibble(
    AOI_ID =
      aoi_sf$AOI_ID,

    AOI_NAME =
      aoi_sf$AOI_NAME,

    AOI_AREA_HA_VECTOR =
      aoi_sf$AOI_AREA_HA_VECTOR,

    scenario =
      scenario,

    period =
      period,

    indicator =
      indicator,

    mean =
      safe_mean(valid_values),

    weighted_mean =
      weighted_mean_value,

    median =
      safe_median(valid_values),

    p75 =
      safe_quantile(
        valid_values,
        0.75
      ),

    p90 =
      safe_quantile(
        valid_values,
        0.90
      ),

    min =
      safe_min(valid_values),

    max =
      safe_max(valid_values),

    n_intersecting_cells =
      nrow(extraction),

    n_valid_cells =
      sum(
        !is.na(extraction$value)
      ),

    valid_covered_area_ha =
      valid_area_m2 / 10000,

    cropped_raster =
      output_raster_file
  )

  cat(
    "Area-weighted mean:",
    round(
      result$weighted_mean,
      4
    ),
    "\n"
  )

  result
}

