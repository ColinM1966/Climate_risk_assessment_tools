build_raster_catalogue <- function(
    include_baseline,
    selected_ssps,
    selected_periods
) {

  catalogue_parts <- list()

  # ----------------------------------------------------------
  # BASELINE
  # ----------------------------------------------------------

  if (include_baseline) {

    baseline_catalogue <- indicator_definitions %>%
      mutate(
        scenario = "baseline",
        period = "1981-2010",
        raster_directory = baseline_dir
      ) %>%
      rowwise() %>%
      mutate(
        candidate_names = list(
          make_candidate_filenames(
            prefixes = candidate_prefixes,
            scenario = scenario,
            period = period,
            extension = extension
          )
        ),

        raster_file = find_existing_file(
          raster_directory,
          candidate_names
        )
      ) %>%
      ungroup() %>%
      select(
        indicator,
        scenario,
        period,
        raster_file
      )

    catalogue_parts[["baseline"]] <-
      baseline_catalogue
  }

  # ----------------------------------------------------------
  # FUTURE SCENARIOS
  # ----------------------------------------------------------

  future_combinations <- expand_grid(
    scenario = selected_ssps,
    period = selected_periods
  )

  future_catalogue <- pmap_dfr(
    future_combinations,
    function(scenario, period) {

      folder_code <- period_folder_codes[
        period
      ]

      if (is.na(folder_code)) {
        stop(
          "No folder code is defined for period: ",
          period
        )
      }

      future_directory <- file.path(
        layers_dir,
        paste0(
          scenario,
          "-",
          folder_code
        )
      )

      indicator_definitions %>%
        mutate(
          scenario = scenario,
          period = period,
          raster_directory =
            future_directory
        ) %>%
        rowwise() %>%
        mutate(
          candidate_names = list(
            make_candidate_filenames(
              prefixes =
                candidate_prefixes,
              scenario = scenario,
              period = period,
              extension = extension
            )
          ),

          raster_file = find_existing_file(
            raster_directory,
            candidate_names
          )
        ) %>%
        ungroup() %>%
        select(
          indicator,
          scenario,
          period,
          raster_file
        )
    }
  )

  catalogue_parts[["future"]] <-
    future_catalogue

  bind_rows(
    catalogue_parts
  ) %>%
    mutate(
      scenario_period = if_else(
        scenario == "baseline",
        "baseline_1981-2010",
        paste(
          scenario,
          period,
          sep = "_"
        )
      )
    ) %>%
    arrange(
      scenario,
      period,
      indicator
    )
}

